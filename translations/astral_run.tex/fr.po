"\\begin{itemize}\n"
"  \\item A ``Pack'' of chosen \\svg{bronze} Units\n"
"  \\item A chosen Neutral \\svg{bronze} Unit matching the player's Faction\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Unités de Départ :}\n"
"\\begin{itemize}\n"
"  \\item Une Unité «Quelques» \\svg{silver}\\ avec le coût de Recrutement le plus faible.\n"
"  \\item Une Unité Neutre \\svg{bronze} de sa Faction.\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:40
#, fuzzy, no-wrap
#| msgid ""
#| "\\begin{itemize}\n"
#| "  \\item P × Starting (I) Map Tile\n"
#| "  \\item 2P × Far (II--III) Map Tile\n"
#| "  \\item 2P × Near (IV--V) Map Tile\n"
#| "  \\item (P + 1) × Center (VI--VII) Map Tile\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\begin{itemize}\n"
"  \\item $P$ × Starting (I) Map Tiles\n"
"  \\item $2P$ × Far (II-III) Map Tiles\n"
"  \\item $P$ × Near (IV-V) Map Tiles\n"
"  \\item 6 × Near (IV-V) Map Tiles with an Obelisk\n"
"  \\item 1 × Center (VI-VII) Map Tile\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\begin{itemize}\n"
"  \\item J × Tuiles de Départ (I)\n"
"  \\item 2J × Tuiles Lointaines (II--III)\n"
"  \\item 2J × Tuiles Proches (IV--V)\n"
"  \\item (J + 1) × Tuiles Centrales (VI--VII)\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:43
#, fuzzy, no-wrap
#| msgid ""
#| "\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
#| "Slay the Dragon Boss with your Main Hero.\n"
#| "\n"
msgid ""
"\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
"The game ends when any of the following conditions are met:\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Conditions de Victoire}}\n"
"Tuer le Boss Dragon avec votre Héros Principal.\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:49
#, no-wrap
msgid ""
"\\begin{itemize}\n"
"  \\item One player has flagged all 6 Obelisks. \\textit{That player wins the game immediately.}\n"
"  \\item \\textbf{4--6 players:} One player has defeated every opponent's Main Hero at least once. \\textit{That player wins the game immediately.}\n"
"  \\item At the end of Round 15.\n"
"\\end{itemize}\n"
"\n"
msgstr ""

#. type: multicols*
#: clash/astral_run.tex:52
#, fuzzy, no-wrap
#| msgid ""
#| "\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
#| "Score the most Victory Points (VPs) by the end of the \\nth{16} Round.\n"
#| "\n"
msgid ""
"\\subsection*{\\MakeUppercase{Victory Points}}\n"
"If no player has achieved an immediate victory, the player with the most Victory Points (VP) wins.\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Conditions de Victoire}}\n"
"Marquer le plus de Points de Victoire (VP) à la fin de la Manche 16.\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:58
#, no-wrap
msgid ""
"\\begin{itemize}\n"
"  \\item 4 VPs for the first player to flag the Center VII Field.\n"
"  \\item 2 VPs for each enemy Main Hero defeated.\n"
"  \\item 1 VP for each flagged Obelisk.\n"
"\\end{itemize}\n"
"\n"
msgstr ""

#. type: multicols*
#: clash/astral_run.tex:80
#, fuzzy, no-wrap
#| msgid ""
#| "\\textbf{\\nth{1} Round:}\n"
#| "\\begin{itemize}\n"
#| "  \\item All Heroes gain +1 \\svg{movement}.\n"
#| "\\end{itemize}\n"
#| "\\textbf{\\nth{6} and \\nth{9} Rounds:}\n"
#| "\\begin{itemize}\n"
#| "  \\item Remove all Black Cubes from every Water Wheel and Windmill on the map.\n"
#| "\\end{itemize}\n"
#| "\\textbf{\\nth{10} Round:}\n"
#| "\\begin{itemize}\n"
#| "  \\item Player(s) whose Main Hero has the least experience roll 2 \\svg{resource}.\n"
#| "\\end{itemize}\n"
#| "\\textbf{\\nth{12} Round:}\n"
#| "\\begin{itemize}\n"
#| "  \\item Repeat event of Round 6.\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\subsection*{\\MakeUppercase{Timed Events}}\n"
"\\textbf{\\nth{4} Round:}\n"
"\\begin{itemize}\n"
"  \\item Remove all Black Cubes from the Map, except those on Learning Stones.\n"
"\\end{itemize}\n"
"\\textbf{\\nth{6} Round:}\n"
"\\begin{itemize}\n"
"  \\item Player(s) whose Main Hero has the least \\svg{experience}, Search (2) \\svg{artifact}.\n"
"\\end{itemize}\n"
"\\textbf{\\nth{8} Round:}\n"
"\\begin{itemize}\n"
"  \\item Repeat the event of Round 4.\n"
"\\end{itemize}\n"
"\\textbf{\\nth{10} Round:}\n"
"\\begin{itemize}\n"
"  \\item Player(s) whose Main Hero has the least \\svg{experience}, roll and resolve \\svg{resource} twice.\n"
"\\end{itemize}\n"
"\\textbf{\\nth{12} Round:}\n"
"\\begin{itemize}\n"
"  \\item Repeat the event of Round 4.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Manche 1:}\n"
"\\begin{itemize}\n"
"  \\item Les Héros gagnent +1 \\svg{movement}.\n"
"\\end{itemize}\n"
"\\textbf{Manches 6 et 9:}\n"
"\\begin{itemize}\n"
"  \\item Retirez les Cubes Noirs de chaque Moulin à Eau et Moulin à Vent sur le Plateau.\n"
"\\end{itemize}\n"
"\\textbf{Manche 10:}\n"
"\\begin{itemize}\n"
"  \\item Le Joueur dont le Héros Principal a le moins d'expérience lances 2 \\svg{resource}.\n"
"\\end{itemize}\n"
"\\textbf{Manche 12:}\n"
"\\begin{itemize}\n"
"  \\item Repetez les évènements de la Manche 6.\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:90
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Additional Rules}}\n"
"\\begin{itemize}\n"
"  \\item The Blocked Field on the Map Tile in the center is not considered blocked.\n"
"  \\item \\textbf{Sanctuary:} Search (2) your Deck. \\textit{Visitable once per Faction}.\n"
"  \\item \\textbf{Obelisk:} Guarded by Level VI Neutral Units. \\\\ \\textbf{First to Flag:} Search (4) \\svg[8]{skill}, \\svg{spellpower} or \\svg{artifact}.\n"
"  \\item Each \\textbf{blocked Field} adjacent to an Obelisk is a two-way Astral Gate, which only becomes active after that Obelisk has been visited.\n"
"  \\item \\textbf{Astral Gate:} Cannot be entered from a different Map Tile. When a Hero enters an Astral Gate, they are teleported to the Astral Gate on the Near Tile directly opposite the Center Tile. If that Tile is undiscovered, that player immediately discovers it.\n"
"  \\item Gain 1 \\svg{experience} after a Combat against an enemy Main Hero, unless one of the players surrenders or retreats.\n"
"\\end{itemize}\n"
"\n"
msgstr ""

