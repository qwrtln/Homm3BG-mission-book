"\\end{center}\n"
"\n"

#. type: multicols*
#: clash/astral_run.tex:106
#, no-wrap
msgid ""
"\\begin{itemize}\n"
"  \\item \\textbf{Grail Token:} When gained, Search (4) \\svg{artifact}. \\svg{hand} Limit is increased by 3.\n"
"  \\item \\textbf{Level VII Settlement:} Increase all incomes by 1 space.\n"
"  \\item \\textbf{Random Town:} You may recruit one Faction Unit you defeated for half its recruitment cost or increase all incomes by one space.\n"
"  \\item \\textbf{Dragon Utopia:} Take any Card from your Discard pile. You may recruit one dragon you defeated for half its recruitment cost.\n"
"  \\item \\textbf{11-Round game:} Remove $P$ × Near (IV--V) Map Tiles and replace the Center (VI--VII) Tile with a Near (IV--V) Map Tile without an Obelisk.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\begin{itemize}\n"
"  \\item \\textbf{Żeton Graala:} Po zdobyciu Przeszukaj (4) \\svg{artifact}. Limit \\svg{hand} zwiększa się o 3.\n"
"  \\item \\textbf{Osada Poziomu VII:} Zwiększ wszystkie przychody o 1 pole.\n"
"  \\item \\textbf{Losowe Miasto:} Możesz zrekrutować jedną Jednostkę Frakcji, którą pokonałeś, za połowę kosztu rekrutacji lub zwiększyć wszystkie przychody o jedno pole.\n"
"  \\item \\textbf{Smocza Utopia:} Weź dowolną Kartę ze stosu kart odrzuconych. Możesz zrekrutować jednego smoka, którego pokonałeś, za połowę kosztu rekrutacji.\n"
"  \\item \\textbf{Gra na 11 Rund:} Usuń $P$ × Bliskich (IV--V) Kafelków Mapy i zastąp Centralny (VI--VII) Kafelek Bliskim (IV--V) Kafelkiem Mapy bez Obelisku.\n"
"\\end{itemize}\n"
"\n"

