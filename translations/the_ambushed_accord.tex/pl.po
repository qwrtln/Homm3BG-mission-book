#. type: multicols
#: coops/the_ambushed_accord.tex:48
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
"Every player must defeat the Level VII Neutral Army.\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Warunki Zwycięstwa}}\n"
"Każdy gracz musi pokonać Neutralną Armię VII Poziomu.\n"
"\n"

#. type: multicols
#: coops/the_ambushed_accord.tex:76
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Timed Events}}\n"
"\\textbf{\\nth{2} Round:}\n"
"\\begin{itemize}\n"
"  \\item Build either \\svg{building_special_tent} or \\svg[12]{building_special_gears} for free, ignoring any prerequisite buildings.\n"
"    Prerequisite buildings are not granted and must be built separately to use their effects.\n"
"\\end{itemize}\n"
"\\textbf{End of \\nth{4} Round:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{One player} must fight a Timed Event Fight of 5~×~\\svg{bronze}.\n"
"\\end{itemize}\n"
"\\textbf{End of \\nth{7} Round:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{One player} must fight a Timed Event Fight of 4~×~\\svg{silver}.\n"
"\\end{itemize}\n"
"\\textbf{End of \\nth{9} Round:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{One player} must fight a Timed Event Fight of 3~×~\\svg{golden}.\n"
"\\end{itemize}\n"
"\\textbf{End of \\nth{11} Round:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{One player} must fight a Timed Event Fight of 2~×~\\svg{azure}.\n"
"\\end{itemize}\n"
"\\textbf{End of \\nth{13} Round:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{One player} must fight a Timed Event Fight of 3~×~\\svg{azure}.\n"
"\\end{itemize}\n"
"\\clearpage\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Wydarzenia Czasowe}}\n"
"\\textbf{2. Runda:}\n"
"\\begin{itemize}\n"
"  \\item Zbuduj \\svg{building_special_tent} lub \\svg[12]{building_special_gears} za darmo, ignorując wymagane budynki.\n"
"    Wymagane budynki muszą być zbudowane osobno, aby korzystać z ich efektów.\n"
"\\end{itemize}\n"
"\\textbf{Koniec 4. Rundy:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{Jeden gracz} toczy Wymuszoną Walkę z~5~×~\\svg{bronze}.\n"
"\\end{itemize}\n"
"\\textbf{Koniec 7. Rundy:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{Jeden gracz} toczy Wymuszoną Walkę z~4~×~\\svg{silver}.\n"
"\\end{itemize}\n"
"\\textbf{Koniec 9. Rundy:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{Jeden gracz} toczy Wymuszoną Walkę z~3~×~\\svg{golden}.\n"
"\\end{itemize}\n"
"\\textbf{Koniec 11. Rundy:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{Jeden gracz} toczy Wymuszoną Walkę z~2~×~\\svg{azure}.\n"
"\\end{itemize}\n"
"\\textbf{Koniec 13. Rundy:}\n"
"\\begin{itemize}\n"
"  \\item \\textbf{Jeden gracz} toczy Wymuszoną Walkę z~3~×~\\svg{azure}.\n"
"\\end{itemize}\n"
"\\clearpage\n"
"\n"

#. type: multicols
#: coops/the_ambushed_accord.tex:86
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Additional Rules}}\n"
"\\subsubsection*{\\MakeUppercase{Timed Event Fights}}\n"
"\\begin{itemize}\n"
"  \\item For games with 1--3 players, only one player needs to fight each Timed Event Fight. The players may decide which eligible player will fight.\n"
"  \\item For games with 4 or more players, \\textbf{two players} must each fight a Timed Event Fight when the event occurs.\n"
"  \\item Players are not eligible to fight a Timed Event Fight if they have already won more Timed Event Fights than another player, or if they have no Units.\n"
"  \\item Defeating a Timed Event Fight grants a free \\svg{morale_positive}.\n"
"  \\item If a player is defeated in a Timed Event Fight, their Hero is sent back to their Town with no Units. The remaining Units must be defeated by another player. If no player is eligible to fight, players lose the Scenario.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Dodatkowe Zasady}}\n"
"\\subsubsection*{\\MakeUppercase{Wymuszone Walki}}\n"
"\\begin{itemize}\n"
"  \\item W grach na 1--3 graczy tylko jeden gracz musi stoczyć każdą Wymuszoną Walkę. Gracze mogą zdecydować, który uprawniony gracz będzie walczył.\n"
"  \\item W grach na 4 lub więcej graczami \\textbf{dwóch graczy} musi stoczyć każdą Wymuszoną Walkę.\n"
"  \\item Gracz nie jest uprawniony do stoczenia Wymuszonej Walki, jeśli wygrał już więcej Wymuszonych Walk niż jakikolwiek inny gracz lub jeśli nie ma Jednostek.\n"
"  \\item Wygranie Wymuszonej Walki daje \\svg{morale_positive}.\n"
"  \\item Jeśli gracz zostanie pokonany w Wymuszonej Walce, jego Bohater wraca do Miasta bez Jednostek. Pozostałe Jednostki musi pokonać inny gracz. Jeśli żaden gracz nie jest uprawniony do walki, gracze przegrywają Scenariusz.\n"
"\\end{itemize}\n"
"\n"

#. type: multicols
#: coops/the_ambushed_accord.tex:115
#, no-wrap
msgid ""
"\\subsubsection*{\\MakeUppercase{Other Rules}}\n"
"\\begin{itemize}\n"
"  \\item Collaboratively pay $P$~×~5~\\svg{gold}, $P$~×~3~\\svg{building_materials} and $P$~×~\\svg{valuables} to reveal the Center Map Tile ($P$ stands for the number of players), e.g., 4 players must pay 20~\\svg{gold}, 12~\\svg{building_materials}, and 4~\\svg{valuables}.\n"
"  \\item At the end of every Astrologers Round, players must decide which player gets a free \\svg{morale_positive}.\n"
"  \\item Players may exchange Artifacts and Spells from their hands, as well as Units and Resources, if their Main Heroes are standing on adjacent Fields or if both Heroes are in their own Towns or on an Obelisk.\n"
"  \\item Once a player defeats the Level VII Neutral Army, their Heroes are removed from the Map.\n"
"    They are no longer eligible to fight Timed Event Fights.\n"
"\\end{itemize}\n"
"\\hommtablemulticol[]{22}{\n"
"  \\centering\n"
"  \\medskip\n"
"  \\textbf{Difficulty Settings}\\\\\n"
"  \\bigskip\n"
"  \\begin{tabularx}{0.93\\linewidth}{p{0.28\\linewidth}X}\n"
"    \\darkcell[1.6]{Difficulty} & \\darkcell[1.6]{Changes to \\mbox{Timed} Event Fights} \\\\\n"
"    \\darkcell[1.6]{Easy}\n"
"    & \\lightcell[1.6]{Remove a Unit from every Timed Event Fight.} \\\\\n"
"    \\darkcell[1.6]{Normal}\n"
"    & \\lightcell[1.6]{No Change} \\\\\n"
"    \\darkcell[2.2]{Hard}\n"
"    & \\lightcell[2.2]{Add an Initiative Stack Token\\footref{Stack Token} to a random Unit of the fights on Rounds 4, 7 and 9.} \\\\\n"
"    \\darkcell[1.8]{Impossible}\n"
"    & \\lightcell[1.8]{Add two random Stack Tokens\\footref{Stack Token} to two Units in all fights.} \\\\\n"
"  \\end{tabularx}\n"
"  \\medskip\n"
"}\n"
"\\stepcounter{footnote}\n"
"\\footnotetext{\\label{Stack Token} See Naval-Battles Mission Book for details.}"
msgstr ""
"\\subsubsection*{\\MakeUppercase{Pozostałe Zasady}}\n"
"\\begin{itemize}\n"
"  \\item Wspólnie zapłaćcie $G$~×~5~\\svg{gold}, $G$~×~3~\\svg{building_materials} i $G$~×~\\svg{valuables}, aby odkryć Centralny Kafelek Mapy ($G$ oznacza liczbę graczy), np. 4 graczy musi zapłacić 20~\\svg{gold}, 12~\\svg{building_materials} i 4~\\svg{valuables}.\n"
"  \\item Na końcu każdej Rundy Astrologów gracze decydują, który gracz otrzymuje \\svg{morale_positive}.\n"
"  \\item Gracze mogą wymieniać Artefakty i Zaklęcia z ręki, a także Jednostki i Zasoby, jeśli ich Bohaterowie Główni stoją na sąsiednich Polach lub jeśli obaj Bohaterowie są we własnych Miastach albo na Obeliskach.\n"
"  \\item Gdy gracz pokona Neutralną Armię VII Poziomu, jego Bohaterowie zostają usunięci z Mapy.\n"
"    Nie są już uprawnieni do staczania Wymuszonych Walk.\n"
"\\end{itemize}\n"
"\\hommtablemulticol[]{22}{\n"
"  \\centering\n"
"  \\medskip\n"
"  \\textbf{Zasady Poziomów Trudności}\\\\\n"
"  \\bigskip\n"
"  \\begin{tabularx}{0.93\\linewidth}{p{0.28\\linewidth}X}\n"
"    \\darkcell[1.6]{Poziom Trudności} & \\darkcell[1.6]{Zmiany w Wymuszonych Walkach} \\\\\n"
"    \\darkcell[1.6]{Łatwy}\n"
"    & \\lightcell[1.6]{Usuń jedną \\mbox{Jednostkę} z~każdej \\mbox{Wymuszonej} Walki.} \\\\\n"
"    \\darkcell[1.3]{Normalny}\n"
"    & \\lightcell[1.3]{Bez zmian} \\\\\n"
"    \\darkcell[2.2]{Trudny}\n"
"    & \\lightcell[2.2]{Dodaj Żeton Ulepszenia Inicjatywy\\footref{Stack Token} losowej Jednostce w walkach w Rundach 4., 7. i 9.} \\\\\n"
"    \\darkcell[2.2]{Niemożliwy}\n"
"    & \\lightcell[2.2]{Dodaj dwa losowe Żetony Ulepszonych Jednostek\\footref{Stack Token} dwóm Jednostkom we wszystkich walkach.} \\\\\n"
"  \\end{tabularx}\n"
"  \\medskip\n"
"}\n"
"\\stepcounter{footnote}\n"
"\\footnotetext{\\label{Stack Token} Szczegóły znajdziesz w Księdze Misji rozszerzenia Bitwy Morskie.}"

