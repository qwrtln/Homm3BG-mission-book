#. type: multicols*
#: clash/chain_link.tex:53
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Timed Events}}\n"
"\\textbf{\\nth{2}, \\nth{6}, and \\nth{10} Round:}\n"
"\\begin{itemize}\n"
"  \\item The \\nth{2} player gains 1~\\svg{movement}\n"
"\\end{itemize}\n"
"\n"
msgstr ""

#. type: multicols*
#: clash/chain_link.tex:67
#, no-wrap
msgid ""
"\\subsection*{\\MakeUppercase{Additional Rules}}\n"
"\\begin{itemize}\n"
"  \\item At the start of each Resource Round, choose either extra 1~\\svg{valuables} or 2~\\svg{building_materials}.\n"
"  \\item You don't need to pay \\svg{gold} to defend your Town and can use Cards during siege.\n"
"  \\item Once your Main Hero reaches Level V, all your Heroes gain +1~\\svg{movement} at the start of every Turn.\n"
"  \\item When visiting an Obelisk, choose one:\n"
"    \\begin{itemize}\n"
"      \\item Remove a Card from your hand\n"
"      \\item Gain \\svg{morale_positive}\n"
"      \\item Gain 1~\\svg{movement}\n"
"    \\end{itemize}\n"
"  \\item After winning a combat on the Grail Field, you may recruit one of the Units you just defeated for free.\n"
"\\end{itemize}\n"
"\n"
msgstr ""

