"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Starteinheiten:}\n"
"\\begin{itemize}\n"
"  \\item  Ein Rudel der günstigsten \\svg{bronze}-Einheiten\n"
"  \\item  Wenige der teuersten \\svg{bronze}-Einheiten\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/chain_link.tex:39
#, fuzzy, no-wrap
#| msgid ""
#| "\\begin{itemize}\n"
#| "  \\item P × Starting (I) Map Tile\n"
#| "  \\item 2P × Far (II--III) Map Tile\n"
#| "  \\item 2P × Near (IV--V) Map Tile\n"
#| "  \\item (P + 1) × Center (VI--VII) Map Tile\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\begin{itemize}\n"
"  \\item 2 × Starting (I) Map Tiles\n"
"  \\item 4 × Far (II--III) Map Tiles, 2 of which must contain a Settlement\n"
"  \\item 4 × Near (IV--V) Map Tiles: 2 with an Obelisk, 2 with a Settlement\n"
"  \\item 1 × Center (VI--VII) Map Tile with a Grail\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\begin{itemize}\n"
"  \\item S × Startgebiete (I)\n"
"  \\item 2S × Ferne Gebiete (II-III)\n"
"  \\item 2S × Nahe Gebiete (IV-V)\n"
"  \\item (S + 1) × Zentrale Gebiete (VI-VII)\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/chain_link.tex:41
#, no-wrap
msgid ""
"Place Far and Near Tiles symmetrically, so that Obelisks and Settlements aren't adjacent.\n"
"\n"
msgstr ""

