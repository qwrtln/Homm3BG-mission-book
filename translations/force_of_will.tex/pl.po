#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\textbf{Starting Units:}\n"
"\\begin{itemize}\n"
"  \\item 2 × Few \\svgunit{bronze} units with the \\textit{highest} Recruitment cost\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Jednostki Początkowe:}\n"
"\\begin{itemize}\n"
"  \\item Grupa \\svg{bronze} jednostek o \\textit{najniższym} koszcie rekrutacji\n"
"  \\item Garstka \\svg{bronze} jednostek o \\textit{najwyższym} koszcie rekrutacji\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:32 clash/the_hunt.tex:35
#, no-wrap
msgid ""
"\\textbf{Map tile Pool:} Each player takes 1 random Far (II--III) Map tile\n"
"\n"
msgstr ""
"\\textbf{Pula Kafelków Mapy:} Każdy gracz losuje 1 Daleki (II--III) Kafelek Mapy\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:45
#, fuzzy, no-wrap
#| msgid ""
#| "\\textbf{For a 2-player scenario:}\n"
#| "\\begin{itemize}\n"
#| "  \\item 2 × Starting (I) Map tile\n"
#| "  \\item 2 × Far (II--III) Map tile\n"
#| "  \\item 2 × Near (IV--V) Map tile\n"
#| "  \\item 1 × Center (VI--VII) Map tile; place a Black cube or a miniature representing the Dragon in the center of the tile\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\textbf{For a 2-player scenario:}\n"
"\\begin{itemize}\n"
"  \\item 2 × Starting (I) Map tile\n"
"  \\item 2 × Near (IV--V) Map tile\n"
"  \\item 4 × Far (II--III) Map tile\n"
"  \\item 1 × Center (VI--VII) Map tile, which must contain the Dragon Utopia field\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Dla scenariusza dwuosobowego:}\n"
"\\begin{itemize}\n"
"  \\item 2 × Początkowy (I) Kafelek Mapy\n"
"  \\item 2 × Daleki (II--III) Kafelek Mapy\n"
"  \\item 2 × Bliski (IV--V) Kafelek Mapy\n"
"  \\item 1 × Centralny (VI--VII) Kafelek Mapy; umieść Czarną Kostkę lub figurkę reprezentującą Smoka w centrum Kafelka\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:53
#, fuzzy, no-wrap
#| msgid ""
#| "\\textbf{For a 3-player scenario:}\n"
#| "\\begin{itemize}\n"
#| "  \\item 3 × Starting (I) Map tile\n"
#| "  \\item 3 × Far (II--III) Map tile\n"
#| "  \\item 3 × Near (IV--V) Map tile\n"
#| "  \\item 1 × Center (VI--VII) Map tile; place a Black cube or a miniature representing the Dragon in the center of the tile\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\textbf{For a 4-player scenario:}\n"
"\\begin{itemize}\n"
"  \\item 3 × Starting (I) Map tile\n"
"  \\item 3 × Near (IV--V) Map tile\n"
"  \\item 6 × Far (II--III) Map tile\n"
"  \\item 1 × Center (VI--VII) Map tile, which must contain the Dragon Utopia field\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Dla scenariusza trzyosobowego:}\n"
"\\begin{itemize}\n"
"  \\item 3 × Startowy (I) Kafelek Mapy\n"
"  \\item 3 × Daleki (II--III) Kafelek Mapy\n"
"  \\item 3 × Bliski (IV--V) Kafelek Mapy\n"
"  \\item 1 × Centralny (VI--VII) Kafelek Mapy; umieść Czarną Kostkę lub figurkę reprezentującą Smoka w centrum Kafelka\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:56
#, fuzzy, no-wrap
#| msgid ""
#| "\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
#| "Slay the Dragon Boss with your Main Hero.\n"
#| "\n"
msgid ""
"\\subsection*{\\MakeUppercase{Victory Conditions}}\n"
"To win the scenario, a Hero must Flag the Dragon Utopia field.\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Warunki Zwycięstwa}}\n"
"Zabij Smoczego Władcę Bohaterem Głównym.\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:59
#, fuzzy, no-wrap
#| msgid ""
#| "\\subsection*{\\MakeUppercase{Defeat Conditions}}\n"
#| "If the Dragon Boss still lives at the end of the \\nth{14} round, all players lose the scenario.\n"
#| "\n"
msgid ""
"\\subsection*{\\MakeUppercase{Defeat Conditions}}\n"
"At the end of the \\nth{12} Round, if there is no winner, all players lose the scenario.\n"
"\n"
msgstr ""
"\\subsection*{\\MakeUppercase{Warunki Przegranej}}\n"
"Jeśli Smoczy Władca nadal żyje na koniec 14. rundy, wszyscy gracze przegrywają scenariusz.\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:66
#, fuzzy, no-wrap
#| msgid ""
#| "\\textbf{\\nth{4}, \\nth{8} and \\nth{12} Rounds:}\n"
#| "\\begin{itemize}\n"
#| "  \\item Remove all Black cubes from every Windmill, Water Wheel, and Mystical Garden on the map.\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\textbf{\\nth{4} and \\nth{8} Rounds:}\n"
"\\begin{itemize}\n"
"  \\item Remove all Black cubes from every Water Wheel and Windmill on the map.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Rundy 4., 8. i 12.:}\n"
"\\begin{itemize}\n"
"  \\item Usuń wszystkie Czarne Kostki z każdego Wiatraka, Młyna Wodnego i Mistycznego Ogródu na mapie.\n"
"\\end{itemize}\n"
"\n"

#. type: multicols*
#: clash/force_of_will.tex:71
#, fuzzy, no-wrap
#| msgid ""
#| "\\textbf{\\nth{7} and \\nth{8} Rounds:}\n"
#| "\\begin{itemize}\n"
#| "  \\item Spawn an enemy army following the rules outlined below.\n"
#| "\\end{itemize}\n"
#| "\n"
msgid ""
"\\textbf{(2-P Scenario Only) \\nth{5} and \\nth{9} Rounds:}\n"
"\\begin{itemize}\n"
"  \\item The second player gains 1 \\svg{movement}.\n"
"\\end{itemize}\n"
"\n"
msgstr ""
"\\textbf{Rundy 7. i 8.:}\n"
"\\begin{itemize}\n"
"  \\item Umieść wrogą armię zgodnie z zasadami poniżej.\n"
"\\end{itemize}\n"

#. type: multicols*
#: clash/force_of_will.tex:92
#, no-wrap
msgid ""
"\\begin{itemize}\n"
"  \\item When a player Visits an Obelisk, they roll 2 \\svg{treasure} and choose one to resolve.\n"
"  \\item A player may not use the Diplomacy card to skip Combat on the Dragon Utopia field.\n"
"  \\item When a Hero moves to the Dragon Utopia field, they must fight, depending on chosen difficulty, the following number of Neutral units:\n"
"  \\begin{itemize}[leftmargin=15pt]\n"
"    \\item \\textbf{Easy:} 1 × \\svg{azure}, 2 × \\svg{silver}, 1 × \\svg{bronze}\n"
"    \\item \\textbf{Normal:} 1 × \\svg{azure}, 1 × \\svg{golden}, 2 × \\svg{silver}\n"
"    \\item \\textbf{Hard:} 1 × \\svg{azure}, 3 × \\svg{golden}\n"
"    \\item \\textbf{Impossible:}  2 × \\svg{azure}, 2 × \\svg{golden}\n"
"  \\end{itemize}\n"
"  \\item Follow these steps when Combat begins against Neutral units at the Dragon Utopia:\n"
"  \\begin{itemize}[leftmargin=15pt]\n"
"    \\item Place up to 4 of your unit cards freely onto the center row of the Combat board.\n"
"    \\item The enemy player controlling the Neutral units places each Neutral unit in each of the 4 corners of the Combat board.\n"
"  \\end{itemize}\n"
"\\end{itemize}\n"
"\n"
msgstr ""

